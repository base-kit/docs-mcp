{
  "name": "@easy-base/docs-mcp",
  "version": "1.0.2",
  "description": "为 AI 编程（Claude Code / Cursor 等）提供开源项目的本地、可检索、可验证的官方文档 MCP 服务",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/base-kit/docs-mcp.git"
  },
  "homepage": "https://github.com/base-kit/docs-mcp#readme",
  "bugs": {
    "url": "https://github.com/base-kit/docs-mcp/issues"
  },
  "bin": {
    "docs-mcp": "./bin/docs-mcp.mjs"
  },
  "files": [
    "dist",
    "bin",
    "presets",
    "templates",
    ".mcp.json.template",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node bin/docs-mcp.mjs",
    "index:all": "tsx src/cli/index.ts build --all",
    "lint": "oxlint src/ bin/",
    "format": "oxfmt src/ bin/",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@orama/orama": "^3.1.6",
    "commander": "^12.1.0",
    "execa": "^9.6.0",
    "onnxruntime-node": "^1.27.0",
    "ora": "^8.2.0",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/prompts": "^2.4.9",
    "oxfmt": "^0.6.0",
    "oxlint": "^1.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "ai",
    "docs",
    "documentation",
    "open-source"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT"
}
